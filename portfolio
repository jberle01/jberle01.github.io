<!-- WORK -->
<section id="work">
  <div class="container-wide">
    <div class="section-label">Selected Work</div>
    <h2 class="section-title">From content to systems, at scale.</h2>

    <div class="work-grid">

      <!-- Featured -->
      <div class="work-card work-card-featured">
        <div class="card-icon" style="background: var(--accent);">🤖</div>
