<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Joelle Berlet — Content Designer</title>
  <style>
    :root {
      --ink: #1a1a2e;
      --ink-light: #4a4a6a;
      --ink-muted: #8888aa;
      --accent: #5b4fcf;
      --accent-light: #ede9ff;
      --accent-mid: #a89cef;
      --surface: #ffffff;
      --surface-2: #f7f6fd;
      --surface-3: #f0eefa;
      --border: #e2dff5;
      --tag-bg: #ede9ff;
      --tag-text: #5b4fcf;
      --green: #1a7f5a;
      --green-bg: #e6f7f1;
      --radius: 12px;
      --radius-sm: 6px;
      --shadow: 0 2px 16px rgba(91,79,207,0.07);
      --shadow-hover: 0 6px 28px rgba(91,79,207,0.13);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      color: var(--ink);
      background: var(--surface);
      line-height: 1.65;
    }

    /* NAV */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
    }
    .nav-logo {
      font-weight: 700;
      font-size: 1rem;
      color: var(--accent);
      letter-spacing: -0.01em;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .nav-links a {
      text-decoration: none;
      color: var(--ink-light);
      font-size: 0.875rem;
      font-weight: 500;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--accent); }

    /* SECTIONS */
    section { padding: 5rem 2rem; }
    .container { max-width: 960px; margin: 0 auto; }
    .container-wide { max-width: 1100px; margin: 0 auto; }

    /* HERO */
    .hero {
      background: linear-gradient(135deg, var(--surface-2) 0%, var(--accent-light) 100%);
      padding: 6rem 2rem 5rem;
      border-bottom: 1px solid var(--border);
    }
    .hero-inner {
      max-width: 760px;
      margin: 0 auto;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--accent);
      color: #fff;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.35rem 0.85rem;
      border-radius: 100px;
      margin-bottom: 1.5rem;
    }
    .hero h1 {
      font-size: clamp(2.2rem, 5vw, 3.4rem);
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.03em;
      color: var(--ink);
      margin-bottom: 1rem;
    }
    .hero h1 span { color: var(--accent); }
    .hero-sub {
      font-size: 1.15rem;
      color: var(--ink-light);
      max-width: 620px;
      margin-bottom: 2rem;
    }
    .hero-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 1.25rem;
      font-size: 0.875rem;
      color: var(--ink-light);
    }
    .hero-meta span {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .hero-meta svg { width: 16px; height: 16px; flex-shrink: 0; }

    /* SECTION HEADERS */
    .section-label {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }
    .section-title {
      font-size: clamp(1.6rem, 3vw, 2.1rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-bottom: 0.75rem;
    }
    .section-desc {
      font-size: 1rem;
      color: var(--ink-light);
      max-width: 580px;
      margin-bottom: 3rem;
    }

    /* WORK CARDS */
    .work-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    @media (max-width: 680px) { .work-grid { grid-template-columns: 1fr; } }

    .work-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.75rem;
      transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
      cursor: default;
    }
    .work-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-hover);
      border-color: var(--accent-mid);
    }
    .work-card-featured {
      grid-column: 1 / -1;
      background: linear-gradient(135deg, var(--surface-2), var(--accent-light));
      border-color: var(--accent-mid);
    }
    .card-icon {
      width: 44px;
      height: 44px;
      background: var(--accent-light);
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      font-size: 1.3rem;
    }
    .work-card-featured .card-icon {
      background: var(--accent);
    }
    .card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-bottom: 0.85rem;
    }
    .tag {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      background: var(--tag-bg);
      color: var(--tag-text);
      padding: 0.25rem 0.6rem;
      border-radius: 100px;
    }
    .tag-green {
      background: var(--green-bg);
      color: var(--green);
    }
    .card-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 0.5rem;
      letter-spacing: -0.01em;
    }
    .card-desc {
      font-size: 0.9rem;
      color: var(--ink-light);
      line-height: 1.6;
      margin-bottom: 1rem;
    }
    .card-results {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .card-results li {
      font-size: 0.85rem;
      color: var(--ink-light);
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
      line-height: 1.5;
    }
    .card-results li::before {
      content: '→';
      color: var(--accent);
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 1px;
    }

    /* SKILLS MAP */
    .skills-section {
      background: var(--surface-2);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.25rem;
    }
    .skill-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.4rem 1.5rem;
      transition: box-shadow 0.2s;
    }
    .skill-card:hover { box-shadow: var(--shadow); }
    .skill-card-header {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 0.6rem;
    }
    .skill-icon {
      font-size: 1.1rem;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--accent-light);
      border-radius: 6px;
      flex-shrink: 0;
    }
    .skill-name {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--ink);
      letter-spacing: -0.01em;
    }
    .skill-desc {
      font-size: 0.83rem;
      color: var(--ink-light);
      line-height: 1.5;
    }

    /* ROLE MAP */
    .role-map {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .role-item {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      padding: 1.25rem 1.5rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      align-items: start;
    }
    @media (max-width: 680px) { .role-item { grid-template-columns: 1fr; } }
    .role-requirement {
      font-size: 0.875rem;
      color: var(--ink-light);
      line-height: 1.55;
      padding-right: 1rem;
      border-right: 1px solid var(--border);
    }
    @media (max-width: 680px) { .role-requirement { border-right: none; border-bottom: 1px solid var(--border); padding-right: 0; padding-bottom: 0.75rem; } }
    .role-requirement-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 0.35rem;
    }
    .role-evidence {
      font-size: 0.875rem;
      color: var(--ink);
      line-height: 1.55;
      padding-left: 1rem;
    }
    @media (max-width: 680px) { .role-evidence { padding-left: 0; padding-top: 0.75rem; } }
    .role-evidence-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--green);
      margin-bottom: 0.35rem;
    }

    /* TOOLS */
    .tools-section { background: var(--surface); }
    .tools-clusters {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 1rem;
    }
    @media (max-width: 800px) {
      .tools-clusters { grid-template-columns: repeat(3, 1fr); }
    }
    .tool-cluster {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1rem 1.1rem;
    }
    .tool-cluster-title {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.7rem;
    }
    .tool-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    .tool-list li {
      font-size: 0.85rem;
      color: var(--ink-light);
    }

    /* ABOUT */
    .about-section {
      background: var(--accent);
      color: white;
    }
    .about-inner {
      max-width: 720px;
      margin: 0 auto;
      text-align: center;
    }
    .about-inner .section-label { color: var(--accent-light); }
    .about-inner .section-title { color: #fff; }
    .about-inner .section-desc {
      color: rgba(255,255,255,0.8);
      max-width: none;
      font-size: 1.05rem;
      margin-bottom: 2rem;
    }
    .contact-row {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .contact-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .contact-btn:hover { transform: translateY(-2px); box-shadow: 0 4px 14px rgba(0,0,0,0.2); }
    .btn-white {
      background: #fff;
      color: var(--accent);
    }
    .btn-outline {
      background: transparent;
      color: #fff;
      border: 2px solid rgba(255,255,255,0.5);
    }

    /* STAT ROW */
    .stat-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }
    .stat-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 0.45rem 1rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--ink);
    }
    .stat-pill span.num {
      color: var(--accent);
      font-size: 1rem;
    }

    /* FOOTER */
    footer {
      text-align: center;
      padding: 2rem;
      font-size: 0.8rem;
      color: var(--ink-muted);
      border-top: 1px solid var(--border);
    }

    /* UTIL */
    .divider {
      height: 1px;
      background: var(--border);
      margin: 0;
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <span class="nav-logo">Joelle Berlet</span>
  <ul class="nav-links">
